# Copy to .env.local and fill in. Never commit .env.local.

# Where Studio reads content from. Two modes:
#
#   GSL_CONTENT_SOURCE=onedrive
#     For local dev on Anish's machine. Reads live from the OneDrive folder,
#     so edits Ritu makes in OneDrive show up immediately on refresh without
#     running the sync script. Requires GSL_ONEDRIVE_PATH below.
#
#   GSL_CONTENT_SOURCE=synced
#     For production on Vercel. Reads from committed ./content-synced/ so the
#     build is hermetic and does not depend on any local OneDrive path.
#     Set this (as a Vercel environment variable) on every deployed environment.
#     Also useful locally for verifying a prod build before pushing; run:
#       GSL_CONTENT_SOURCE=synced pnpm build
#
# Refresh flow for prod: `pnpm sync-content` pulls the current OneDrive state
# into ./content-synced/, commit, push, Vercel auto-deploys.
GSL_CONTENT_SOURCE=onedrive

# Absolute path to the locally synced OneDrive "studio" folder.
# Required when GSL_CONTENT_SOURCE=onedrive. Not used on Vercel.
# Quote if the path contains spaces. Windows backslashes are fine in Node; forward slashes also accepted.
GSL_ONEDRIVE_PATH="C:\\Users\\anish\\OneDrive - MAF TECHNOLOGIES PRIVATE LIMITED\\Acads\\studio"

# Shared password for the team (middleware gate). Not authentication, just a door lock.
# Keep it in the team WhatsApp group, rotate if leaked.
GSL_STUDIO_PASSWORD=replace-me-with-something-the-team-knows

# Google Form URL for "Suggest improvement" feedback.
# Playbook reader appends ?entry.<id>=<slug> to this URL.
GSL_FEEDBACK_FORM_URL=https://docs.google.com/forms/d/e/REPLACE/viewform

# Optional. Canonical site URL for metadata. Leave blank in dev.
NEXT_PUBLIC_SITE_URL=
